{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
        "url": "https://raw.githubusercontent.com/VerakarnM/FIT2179_DV2/refs/heads/main/Interstate_Migration_2017_2025.csv"
    },
    "width": 400,
    "transform": [
        {
            "filter": "datum.Measure === 'NIM Arrivals' && datum.Age === 'All ages' && datum.Region != 'Australia'"
        }
    ],
    "mark": {
        "type": "line",
        "interpolate": "monotone"
    },
    "encoding": {
        "x": {
            "field": "TIME_PERIOD",
            "type": "temporal",
            "title": null
        },
        "y": {
            "field": "OBS_VALUE",
            "type":"quantitative",
            "title":"Total Arrivals"
        },
        "color": {
            "type": "nominal",
            "field": "Region",
            "legend":{"orient": "none", "legendX":410, "legendY":5}
        }
    },
    "config": {}
}